import os
import shutil
from textwrap import shorten

import torch
from datasets import Dataset
from llmcompressor import oneshot
from llmcompressor.modifiers.quantization import QuantizationModifier
from llmcompressor.modifiers.transform.smoothquant import SmoothQuantModifier
from transformers import AutoModelForCausalLM, AutoTokenizer

from calibration_data import build_calibration_texts

# 1. 환경 설정
MODEL_ID = "../base_model"
OUT_DIR = "./model"
MAX_SEQ_LENGTH = 768
CALIB_REPEAT = 24
SMOOTHING_STRENGTH = 0.55
SIZE_MODE = "balanced"
SENSITIVE_LAYER_IDS_BY_MODE = {
    "safe": (0, 1, 28, 29),
    "balanced": (0, 29),
    "compact": (),
}
PREVIEW_MAX_NEW_TOKENS = 80
PREVIEW_SYSTEM_PROMPT = (
    "당신은 EXAONE 기반 한국어-영어 도우미입니다. "
    "사용자 요청에 맞춰 간결하고 직접적으로 답변하세요."
)


def build_ignore_patterns():
    ignore = ["lm_head"]
    sensitive_layer_ids = SENSITIVE_LAYER_IDS_BY_MODE[SIZE_MODE]
    for layer_id in sensitive_layer_ids:
        ignore.append(f"model.layers.{layer_id}.self_attn.o_proj")
        ignore.append(f"model.layers.{layer_id}.mlp.down_proj")
    return ignore


def build_smooth_mappings():
    """
    EXAONE4는 Llama 계열처럼 pre-norm이 아니라서 기본 SmoothQuant 매핑이 그대로 맞지 않는다.
    우선 같은 decoder layer 안에서 가장 가까운 경로인
    post_attention_layernorm -> gate_proj/up_proj 만 실험적으로 스무딩한다.
    """
    return [
        (
            [
                "re:model\\.layers\\.[0-9]+\\.mlp\\.gate_proj",
                "re:model\\.layers\\.[0-9]+\\.mlp\\.up_proj",
            ],
            "re:model\\.layers\\.[0-9]+\\.post_attention_layernorm",
        )
    ]


def build_preview_prompts():
    return [
        "대한민국의 수도를 한 문장으로 설명해 주세요.",
        "다음 내용을 한 줄 JSON으로 작성해 주세요. 이름은 EXAONE 버전은 4.0 파라미터는 1.2B입니다.",
        "Explain why quantization can improve inference efficiency in one sentence.",
        "에너지 절약이 중요한 이유를 두 문장으로 설명해 주세요.",
        "인공지능 모델 경량화의 장점을 세 줄 목록으로 작성해 주세요.",
        "사과 2개와 배 3개가 있을 때 총 몇 개인지 답해 주세요.",
        "다음 문장을 정중하게 바꿔 주세요. 오늘 밤 서비스가 잠시 중단됩니다.",
        "기후 변화가 무엇인지 쉼표를 쓰지 말고 설명해 주세요.",
        "Write a short answer about why reliable formatting matters for assistant models.",
        "파이썬에서 리스트 길이를 구하는 방법을 한 문장으로 설명해 주세요.",
    ]


def format_prompt(tokenizer, prompt):
    if getattr(tokenizer, "chat_template", None):
        messages = [
            {"role": "system", "content": PREVIEW_SYSTEM_PROMPT},
            {"role": "user", "content": prompt},
        ]
        return tokenizer.apply_chat_template(
            messages,
            tokenize=False,
            add_generation_prompt=True,
            skip_think=True,
        )

    return f"[|system|]\n{PREVIEW_SYSTEM_PROMPT}\n[|endofturn|]\n[|user|]\n{prompt}\n[|endofturn|]\n[|assistant|]\n"


def clean_preview_output(text):
    cleaned = text.strip()

    if "</think>" in cleaned:
        cleaned = cleaned.split("</think>")[-1].strip()

    for marker in ("[|assistant|]", "[|endofturn|]", "[EOS]"):
        cleaned = cleaned.replace(marker, "").strip()

    return cleaned or "<EMPTY>"


@torch.no_grad()
def preview_generation(model, tokenizer, prompts, title):
    print(f"\n[PREVIEW] {title}")
    was_training = model.training
    model.eval()

    for idx, prompt in enumerate(prompts, start=1):
        formatted_prompt = format_prompt(tokenizer, prompt)
        inputs = tokenizer(formatted_prompt, return_tensors="pt").to(model.device)
        output_ids = model.generate(
            **inputs,
            max_new_tokens=PREVIEW_MAX_NEW_TOKENS,
            do_sample=False,
            use_cache=True,
            pad_token_id=tokenizer.eos_token_id,
        )
        prompt_length = inputs["input_ids"].shape[-1]
        new_token_ids = output_ids[0][prompt_length:]
        generated = tokenizer.decode(new_token_ids, skip_special_tokens=False)
        generated = clean_preview_output(generated)

        print(f"[PREVIEW {idx}] PROMPT: {shorten(prompt, width=120, placeholder='...')}")
        print(f"[PREVIEW {idx}] OUTPUT: {generated}")
        print("[PREVIEW] ---")

    if was_training:
        model.train()


calibration_texts = build_calibration_texts()
dataset = Dataset.from_dict({"text": calibration_texts})
ignore_patterns = build_ignore_patterns()
smooth_mappings = build_smooth_mappings()
preview_prompts = build_preview_prompts()

print("[INFO] 모델 로드 중...")
tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
model = AutoModelForCausalLM.from_pretrained(
    MODEL_ID,
    torch_dtype=torch.bfloat16,
    device_map="auto",
    trust_remote_code=True,
)

recipe = [
    SmoothQuantModifier(
        smoothing_strength=SMOOTHING_STRENGTH,
        mappings=smooth_mappings,
        ignore=["lm_head"],
        num_calibration_steps=len(calibration_texts),
    ),
    QuantizationModifier(
        targets="Linear",
        scheme="W8A8",
        ignore=ignore_patterns,
    ),
]

print("[INFO] EXAONE4 SmoothQuant 실험 모드")
print("[INFO] attention qkv 경로는 구조상 정석 매핑이 어려워 MLP 경로만 스무딩합니다.")
print(f"[INFO] calibration 샘플 수: {len(calibration_texts)}")
print(f"[INFO] max_seq_length: {MAX_SEQ_LENGTH}")
print(f"[INFO] smoothing_strength: {SMOOTHING_STRENGTH}")
print(f"[INFO] size_mode: {SIZE_MODE}")
print(f"[INFO] smooth mappings: {smooth_mappings}")
print(f"[INFO] quantization ignore: {ignore_patterns}")

preview_generation(
    model,
    tokenizer,
    preview_prompts,
    "양자화 전 샘플 출력",
)

oneshot(
    model=model,
    dataset=dataset,
    recipe=recipe,
    max_seq_length=MAX_SEQ_LENGTH,
    num_calibration_samples=len(calibration_texts),
    shuffle_calibration_samples=False,
)

preview_generation(
    model,
    tokenizer,
    preview_prompts,
    "양자화 후 샘플 출력",
)

print(f"[INFO] 모델 저장: {OUT_DIR}")
os.makedirs(OUT_DIR, exist_ok=True)
model.save_pretrained(OUT_DIR)
tokenizer.save_pretrained(OUT_DIR)

print("[INFO] 제출 zip 파일 생성 중...")
zip_name = "submit"
if os.path.exists(f"{zip_name}.zip"):
    os.remove(f"{zip_name}.zip")
shutil.make_archive(zip_name, "zip", root_dir=".", base_dir=os.path.basename(OUT_DIR))

print(
    f"[INFO] 완료! 최종 파일 크기: {os.path.getsize(f'{zip_name}.zip') / (1024 ** 3):.2f} GB"
)
