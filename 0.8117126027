import os
import zipfile
from pathlib import Path

import torch
from compressed_tensors.quantization import QuantizationArgs
from datasets import Dataset
from llmcompressor import oneshot
from llmcompressor.modifiers.quantization import QuantizationModifier
from transformers import AutoModelForCausalLM, AutoTokenizer

from calibration_data import DEFAULT_CATEGORY_WEIGHTS, build_calibration_texts


os.environ.setdefault("CUDA_VISIBLE_DEVICES", "1")

BASE_DIR = Path(__file__).resolve().parent
MODEL_ID = str((BASE_DIR / "../base_model").resolve())
OUT_DIR = BASE_DIR / "model"
OUTPUT_DIR = BASE_DIR / "output"
SUBMIT_ZIP = BASE_DIR / "submit.zip"
MODEL_DTYPE = torch.bfloat16
KV_CACHE_MODE = "fp8"  # "none" | "fp16" | "fp8"
MAX_SEQ_LENGTH = 512
CALIB_REPEAT = 16

# 성능이 잘 나왔던 분포를 유지하면서 IFEVAL 성격만 조금 더 보강한다.
CATEGORY_WEIGHTS = DEFAULT_CATEGORY_WEIGHTS.copy()
CATEGORY_WEIGHTS["format_following"] = 5
CATEGORY_WEIGHTS["kr_qa"] = 5

EXTRA_IFEVAL_TEXTS = [
    "질문: 답변은 반드시 두 문장으로 작성하고 모든 문장은 '~합니다'로 끝내세요. 에너지 절약이 중요한 이유를 설명하세요.\n답변: 에너지 절약은 비용을 줄이는 데 도움이 됩니다. 또한 자원 낭비를 줄여 환경 보호에 기여합니다.",
    "질문: 아래 정보를 바탕으로 JSON만 출력하세요. city=Seoul country=Korea population=large\n답변: {\"city\": \"Seoul\", \"country\": \"Korea\", \"population\": \"large\"}",
    "질문: 응답에 숫자 2를 포함하고 마지막은 마침표로 끝나게 작성하세요. 계획을 간단히 설명해 주세요.\n답변: 2단계 계획으로 먼저 데이터를 정리하고 이후 모델을 검증합니다.",
    "질문: 인공지능을 설명하되 쉼표를 쓰지 말고 25자 이내 한 문장으로 답하세요.\n답변: 인공지능은 학습과 추론을 수행하는 기술입니다.",
    "질문: 다음 내용을 세 줄 목록으로 작성하세요. 모델 압축의 장점\n답변: 1. 메모리 사용량 감소\n2. 추론 속도 향상\n3. 배포 효율성 개선",
    "질문: Return a JSON object with keys name, version, parameters for EXAONE 4.0 1.2B.\n답변: {\"name\": \"EXAONE\", \"version\": \"4.0\", \"parameters\": \"1.2B\"}",
    "질문: Explain why quantization can improve inference speed in one sentence.\n답변: Quantization speeds up inference by reducing numerical precision so the model needs less memory bandwidth and faster arithmetic.",
    "질문: 사과 2개와 배 3개가 있을 때 총 몇 개인지 답하세요.\n답변: 총 5개입니다.",
]


def build_kv_cache_scheme(mode: str):
    mode = mode.lower()

    if mode in {"none", "fp16"}:
        return None

    if mode == "fp8":
        return QuantizationArgs(
            num_bits=8,
            type="float",
            strategy="tensor",
            symmetric=True,
            dynamic=True,
        )

    raise ValueError(f"지원하지 않는 KV_CACHE_MODE={mode}")


def build_calibration_dataset() -> Dataset:
    calibration_texts = build_calibration_texts(
        repeat=CALIB_REPEAT,
        category_weights=CATEGORY_WEIGHTS,
    )
    calibration_texts.extend(EXTRA_IFEVAL_TEXTS * CALIB_REPEAT)
    return Dataset.from_dict({"text": calibration_texts})


def find_latest_vllm_whl():
    whl_files = sorted(OUTPUT_DIR.glob("vllm-*.whl"), key=lambda p: p.stat().st_mtime)
    return whl_files[-1] if whl_files else None


def create_submit_zip(model_dir: Path) -> None:
    vllm_whl = find_latest_vllm_whl()

    if SUBMIT_ZIP.exists():
        SUBMIT_ZIP.unlink()

    with zipfile.ZipFile(SUBMIT_ZIP, "w", zipfile.ZIP_DEFLATED) as zf:
        for file_path in model_dir.rglob("*"):
            if file_path.is_file():
                arcname = Path("model") / file_path.relative_to(model_dir)
                zf.write(file_path, arcname.as_posix())

        if vllm_whl is not None:
            zf.write(vllm_whl, vllm_whl.name)

    print(f"[INFO] submit zip: {SUBMIT_ZIP}")
    if vllm_whl is not None:
        print(f"[INFO] included vllm wheel: {vllm_whl}")
    else:
        print("[WARN] hong/output 에 vllm wheel이 없어 model/만 submit.zip에 포함했습니다.")


def main():
    dataset = build_calibration_dataset()
    calibration_size = len(dataset)

    print(f"[INFO] CUDA_VISIBLE_DEVICES={os.environ.get('CUDA_VISIBLE_DEVICES')}")
    print("[INFO] 모델 로드 중...")
    print(f"[INFO] calibration samples={calibration_size}")
    print(f"[INFO] max_seq_length={MAX_SEQ_LENGTH}")
    print(f"[INFO] kv_cache_mode={KV_CACHE_MODE}")

    tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
    model = AutoModelForCausalLM.from_pretrained(
        MODEL_ID,
        dtype=MODEL_DTYPE,
        device_map="auto",
        trust_remote_code=True,
    )

    recipe = [
        QuantizationModifier(
            targets="Linear",
            scheme="W8A8",
            ignore=["lm_head"],
            kv_cache_scheme=build_kv_cache_scheme(KV_CACHE_MODE),
        )
    ]

    print("[INFO] 양자화 시작...")
    oneshot(
        model=model,
        dataset=dataset,
        recipe=recipe,
        max_seq_length=MAX_SEQ_LENGTH,
        num_calibration_samples=calibration_size,
    )

    print(f"[INFO] 모델 저장: {OUT_DIR}")
    
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    model.save_pretrained(OUT_DIR)
    tokenizer.save_pretrained(OUT_DIR)

    if KV_CACHE_MODE == "fp16":
        print(
            "[INFO] KV cache는 FP16으로 사용할 예정입니다. "
            "이 경우 kv_cache_scheme는 저장하지 않고 추론 시 dtype으로 제어하세요."
        )
    elif KV_CACHE_MODE == "fp8":
        print("[INFO] FP8 KV cache scheme가 모델 config에 저장됩니다.")

    print("[INFO] 제출 zip 파일 생성 중...")
    create_submit_zip(OUT_DIR)
    print(f"[INFO] ✅ 완료! submit.zip 크기: {SUBMIT_ZIP.stat().st_size / (1024**3):.2f} GB")


if __name__ == "__main__":
    main()
